{
	"name": "pict-section-modal",
	"version": "1.3.2",
	"description": "Pict modal section -- confirmations, tooltips, toast notifications, floating modal windows, and viewport-managing layout shells with collapsible / resizable / overlay panels",
	"main": "source/Pict-Section-Modal.js",
	"scripts": {
		"start": "node source/Pict-Section-Modal.js",
		"build": "npx quack build",
		"test": "npx quack test",
		"tests": "npx quack test -g",
		"coverage": "npx quack coverage",
		"example": "npx quack examples"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/fable-retold/pict-section-modal.git"
	},
	"author": "steven velozo <steven@velozo.com>",
	"license": "MIT",
	"bugs": {
		"url": "https://github.com/fable-retold/pict-section-modal/issues"
	},
	"homepage": "https://github.com/fable-retold/pict-section-modal#readme",
	"devDependencies": {
		"browser-env": "^3.3.0",
		"pict": "^1.0.372",
		"pict-docuserve": "^1.4.4",
		"quackage": "^1.3.0"
	},
	"mocha": {
		"diff": true,
		"extension": [
			"js"
		],
		"package": "./package.json",
		"reporter": "spec",
		"slow": "75",
		"timeout": "5000",
		"ui": "tdd",
		"watch-files": [
			"source/**/*.js",
			"test/**/*.js"
		],
		"watch-ignore": [
			"lib/vendor"
		]
	},
	"dependencies": {
		"pict-view": "^1.0.68"
	}
}
